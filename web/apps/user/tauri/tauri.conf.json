{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "webtplmst",
  "version": "0.1.0",
  "identifier": "webtplmst",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm gen"
  },
  "app": {
    "windows": [
      {
        "title": "webtplmst",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
